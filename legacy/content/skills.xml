<skills>
    <category name="Combat">
        <description>Combat skills are used during combat to make use of weapons or to understand the combat situation.</description>
        <skill name="Artillery" trait="INT">
            <text>
                This skill describes how well a character operates a piece of artillery like a fixed cannon, a mobile artillery gun, or a tank gun. This includes the ability to load ammunition, point to a target, and fire the gun. Selecting a target and computing the coordinates is not covered by this skill but by the appropriate Science skill.
            </text>
        </skill>      
        <skill name="Melee Combat [Weapon Category]" trait="STR">
            <text>Description</text>
            <list title="Melee Weapon Categories" sorted="yes">
                <item>Swords</item>
                <item>Hammers and Axes</item>
                <item>Sabres</item>
                <item>Simple Weapons</item>
                <item>Bare Hands</item>
                <item>Pole Arms</item>
                <item>Duel Weapons</item>
            </list>
        </skill>
        <skill name="Ranged Combat [Weapon Category]" trait="AGI">
            <list title="Ranged Weapon Categories" sorted="yes">
                <item>Bows</item>
                <item>Crossbows</item>
                <item>Thrown Weapons</item>
                <item>Hand Weapons</item>
                <item>Manual Rifles</item>
                <item>Automatic Rifles</item>
                <item>Heavy Weapons</item>
            </list>
        </skill>
        <skill name="Tactics" trait="INT">
            <text>
                This skill describes how well a character understands a combat situation and how they can influence the flow of events to benefit to their party.
            </text>
        </skill>  
